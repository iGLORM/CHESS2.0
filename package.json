{
  "name": "chess-2.0",
  "version": "1.0.0",
  "description": "Chess 2.0 — A Pixel Chess Adventure",
  "author": "iGLORM",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.iglorm.chess2",
    "productName": "Chess 2.0",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "launch.sh",
      "chess2.desktop",
      "src/**/*",
      "assets/**/*",
      "icon.png",
      "icon.ico",
      "icon_512.png",
      "icon_1024.png"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "icon_1024.png",
      "category": "public.app-category.board-games"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icon_512.png",
      "category": "Game",
      "desktop": {
        "Name": "Chess 2.0",
        "Comment": "A Pixel Chess Adventure with PixiJS",
        "Categories": "Game;BoardGame;",
        "StartupNotify": "true"
      }
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.6",
    "stockfish": "^18.0.7"
  }
}
